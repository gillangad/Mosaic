{
	"name": "mosaic",
	"version": "0.1.0",
	"type": "module",
	"description": "A glassy desktop workspace for tiled terminal panes.",
	"license": "MIT",
	"author": "Mosaic Contributors",
	"main": "electron/main.mjs",
	"scripts": {
		"dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
		"dev:renderer": "vite",
		"dev:electron": "wait-on tcp:5181 && cross-env ELECTRON_RENDERER_URL=http://localhost:5181 electron .",
		"build": "vite build",
		"start": "electron .",
		"package": "npm run build && electron-builder --config electron-builder.json"
	},
	"dependencies": {
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"@monaco-editor/react": "^4.7.0",
		"framer-motion": "^11.18.2",
		"ignore": "^7.0.5",
		"monaco-editor": "^0.53.0",
		"node-pty": "^1.1.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-markdown": "^10.1.0",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1",
		"xterm": "^5.3.0",
		"xterm-addon-fit": "^0.8.0",
		"xterm-addon-search": "^0.13.0",
		"xterm-addon-serialize": "^0.11.0",
		"xterm-addon-unicode11": "^0.6.0",
		"xterm-addon-web-links": "^0.9.0",
		"xterm-addon-webgl": "^0.16.0"
	},
	"devDependencies": {
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.4.1",
		"concurrently": "^9.1.2",
		"cross-env": "^7.0.3",
		"electron": "^35.0.0",
		"electron-builder": "^26.8.1",
		"typescript": "^5.8.2",
		"vite": "^5.4.14",
		"wait-on": "^8.0.3"
	}
}
